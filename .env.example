# ============================================================
# SecureShop - Environment Variables
# Copy to .env and fill in real values. NEVER commit .env !
# ============================================================

# Shared secret for JWT signing (all services must share this)
JWT_SECRET=CHANGE_ME_USE_VAULT_IN_PRODUCTION

# Shared Postgres password (each service uses its own DB)
POSTGRES_PASSWORD=CHANGE_ME

# RabbitMQ
RABBITMQ_PASSWORD=CHANGE_ME

# Notification Service (SMTP)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@secureshop.local
